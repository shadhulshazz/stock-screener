# API Keys
CLAUDE_API_KEY=your_claude_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Google Sheets (optional)
GOOGLE_SHEETS_CREDENTIALS=path/to/credentials.json
GOOGLE_SHEETS_ID=your_sheet_id

# Zerodha Kite (optional - for live data)
ZERODHA_API_KEY=your_api_key
ZERODHA_API_SECRET=your_api_secret
ZERODHA_ACCESS_TOKEN=your_access_token

# Screening Parameters
ATR_MIN=8
ATR_MAX=25
RSI_MIN=35
RSI_MAX=55
VOLUME_RATIO_MIN=1.5
DELIVERY_PERCENT_MIN=45
PRICE_RANGE_PERCENT=2

# Stock Universe
WATCHLIST_SIZE=75
MIN_PRICE=500
MAX_PRICE=3000

# AI Configuration
AI_PROVIDER=claude  # Options: claude, groq
CONFIDENCE_THRESHOLD=75  # Only alert if AI confidence >= this
TARGET_MOVE_RANGE=10  # ±INR target move

# Deployment
ENVIRONMENT=production  # Options: development, staging, production
DEBUG=False
LOG_LEVEL=INFO

# Backtesting
BACKTEST_START_DATE=2025-01-01
BACKTEST_END_DATE=2026-06-22
